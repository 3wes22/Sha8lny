# ===========================================
# Sha8alny Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ===========================================
# Django Settings
# ===========================================
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here-change-in-production
# Optional: separate signing key for JWT tokens (defaults to SECRET_KEY)
# JWT_SIGNING_KEY=your-jwt-signing-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
DB_NAME=sha8alny_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://127.0.0.1:6379/1

# ===========================================
# Celery Configuration
# ===========================================
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# ===========================================
# CORS Configuration
# ===========================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# ===========================================
# Email Configuration (Production)
# ===========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@sha8alny.com

# ===========================================
# AI/LLM Configuration — Hosted Gemini (default)
# ===========================================
# Active provider
AI_PROVIDER=gemini

# Hosted Gemini API
GEMINI_API_KEY= #api key
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_FLASH_LITE_MODEL=gemini-2.5-flash-lite
GEMINI_FLASH_MODEL=gemini-2.5-flash

# Shared inference settings
LLM_TIMEOUT_SECONDS=60
LLM_RETRY_COUNT=2
LLM_RETRY_BACKOFF_SECONDS=1.0
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=1536

# Optional Ollama emergency fallback (only if AI_PROVIDER=ollama)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=gemma4:e2b
# OLLAMA_NUM_CTX=4096

# Course embedding index (roadmap matching)
# COURSE_VECTOR_DB_PATH=<Backend>/data/course_vector_db

# Celery AI queue (single-lane — one inference at a time)
AI_CELERY_QUEUE=ai
AI_CELERY_CONCURRENCY=1
AI_TASK_SOFT_TIME_LIMIT=120
AI_TASK_HARD_TIME_LIMIT=180

# Retrieval / embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
# CHROMA_PERSIST_DIR=  # leave empty to use ai-models default

# ===========================================
# External API Keys
# ===========================================
# Udemy Affiliate API
UDEMY_CLIENT_ID=your-udemy-client-id
UDEMY_CLIENT_SECRET=your-udemy-client-secret

# YouTube Data API
YOUTUBE_API_KEY=your-youtube-api-key

# Coursera API (if available)
COURSERA_API_KEY=your-coursera-api-key

# ===========================================
# Auth0 Configuration
# ===========================================
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=your-auth0-api-identifier

# ===========================================
# Production-Only Settings
# ===========================================
# Sentry DSN (Error Tracking)
SENTRY_DSN=your-sentry-dsn-here

# Custom Admin URL (for security in production)
ADMIN_URL=admin/

# ===========================================
# Job Scraping Configuration
# ===========================================
# Proxy settings (if needed for scraping)
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ===========================================
# File Storage (Future - AWS S3)
# ===========================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# ===========================================
# Monitoring & Analytics
# ===========================================
# Google Analytics Tracking ID
# GA_TRACKING_ID=

# ===========================================
# Development Settings
# ===========================================
# Set to True to enable Django Debug Toolbar
# ENABLE_DEBUG_TOOLBAR=False
